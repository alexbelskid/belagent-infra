# AppFlowy Cloud — Environment Variables
# Copy to .env and fill in secrets before `docker compose up -d`
#
# On VPS: /opt/appflowy/.env (auto-generated by scripts/deploy-appflowy.sh)

# ── Domain & Scheme ──────────────────────────────────────────
# Set to the client's belagent domain (e.g., grigory.belagent.com)
FQDN=CLIENT.belagent.com
SCHEME=https
WS_SCHEME=wss

# ── Nginx Port (internal, not exposed to internet) ──────────
# Belagent nginx proxies /appflowy/ → localhost:8025
NGINX_PORT=8025

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=appflowy
POSTGRES_PASSWORD=<generated-at-deploy-time>
POSTGRES_DB=appflowy

# ── Redis ────────────────────────────────────────────────────
# No password needed (localhost only, Docker network isolated)

# ── MinIO (S3-compatible storage) ────────────────────────────
AWS_ACCESS_KEY=<generated-at-deploy-time>
AWS_SECRET=<generated-at-deploy-time>

# ── GoTrue (Auth) ────────────────────────────────────────────
GOTRUE_JWT_SECRET=<generated-at-deploy-time-min-32-chars>
GOTRUE_JWT_EXP=604800
GOTRUE_ADMIN_EMAIL=admin@CLIENT.belagent.com
GOTRUE_ADMIN_PASSWORD=<generated-at-deploy-time>
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_DISABLE_SIGNUP=true

# ── AppFlowy Cloud ───────────────────────────────────────────
APPFLOWY_S3_BUCKET=appflowy
APPFLOWY_DATABASE_MAX_CONNECTIONS=20
APPFLOWY_WEBSOCKET_MAILBOX_SIZE=2000
RUST_LOG=info

# ── Agent Service Account (for MCP server) ───────────────────
# Created by deploy-appflowy.sh via GoTrue admin API
APPFLOWY_AGENT_EMAIL=agent@local.belagent
APPFLOWY_AGENT_PASSWORD=<generated-at-deploy-time>
