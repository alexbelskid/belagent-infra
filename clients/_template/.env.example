# Copy this to clients/<name>/.env and fill in values
# .env files are gitignored — never commit secrets

ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=123456:ABC...
BRAVE_API_KEY=BSAS...

# Cloudflare (for setup-client.sh tunnel creation)
CF_API_TOKEN=cfat_...
CF_ACCOUNT_ID=9443beceed90c778812b721dadb4c485
CLIENT_EMAIL=client@gmail.com

# Optional overrides
# OPENCLAW_PORT=19789
# CLIENT_SUBDOMAIN=clientname
# GATEWAY_TOKEN=auto-generated-if-empty
# GROQ_API_KEY=gsk_...

# Client identification (for SOUL.md/HEARTBEAT.md templates)
# CLIENT_NAME=Имя
# CLIENT_CHAT_ID=123456789
# DEVELOPER_CHAT_ID=313978390
